{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CharlieCardenasToledo/instructional-designer-skill/config/notebooks.schema.json",
  "title": "Instructional Designer NotebookLM registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "courses"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "courses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["courseCode", "courseName", "rootPath", "notebookId", "notebookUrl"],
        "properties": {
          "courseCode": { "type": "string", "minLength": 1 },
          "courseName": { "type": "string", "minLength": 1 },
          "rootPath": { "type": "string", "minLength": 1 },
          "notebookId": { "type": "string" },
          "notebookUrl": {
            "type": "string",
            "pattern": "^(|https://notebooklm\\.google\\.com/notebook/.+)$"
          }
        }
      }
    }
  }
}

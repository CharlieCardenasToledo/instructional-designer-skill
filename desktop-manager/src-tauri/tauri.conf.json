{
  "productName": "Instructional Designer Manager",
  "version": "0.1.0",
  "identifier": "com.charliecardenas.ids-manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Instructional Designer Manager",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "windows": {
      "wix": {
        "language": "es-ES"
      },
      "nsis": {
        "languages": ["SpaES"],
        "installMode": "perUser"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "execute": true
    },
    "fs": {
      "all": true,
      "scope": ["$HOME/.claude/**", "$APPDATA/**", "$DOCUMENT/**"]
    }
  }
}
